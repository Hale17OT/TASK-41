# REQUIRED: Fill ALL values before starting. Do NOT use placeholders in production.
# Generate AES/HMAC keys: openssl rand -hex 32

# Database
JDBC_URL=jdbc:mysql://db:3306/dispatchops?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
DB_ROOT_PASSWORD=
DB_USER=dispatchops_app
DB_PASSWORD=

# Encryption keys (exactly 64 hex characters each)
AES_SECRET_KEY=
HMAC_SECRET_KEY=

# For local (non-Docker) development, set:
# JDBC_URL=jdbc:mysql://localhost:3306/dispatchops?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
