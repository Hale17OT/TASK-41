<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.dispatchops.infrastructure.persistence.mapper.ShippingTemplateMapper">

    <resultMap id="ShippingTemplateResultMap" type="ShippingTemplate">
        <id property="id" column="id"/>
        <result property="name" column="name"/>
        <result property="description" column="description"/>
        <result property="active" column="is_active"/>
        <result property="createdBy" column="created_by"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <select id="findById" resultMap="ShippingTemplateResultMap">
        SELECT * FROM shipping_templates WHERE id = #{id}
    </select>

    <select id="findAll" resultMap="ShippingTemplateResultMap">
        SELECT * FROM shipping_templates ORDER BY id LIMIT #{limit} OFFSET #{offset}
    </select>

    <insert id="insert" parameterType="ShippingTemplate" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO shipping_templates (name, description, is_active, created_by)
        VALUES (#{name}, #{description}, #{active}, #{createdBy})
    </insert>

    <update id="update" parameterType="ShippingTemplate">
        UPDATE shipping_templates
        SET name        = #{name},
            description = #{description},
            is_active   = #{active},
            updated_at  = NOW()
        WHERE id = #{id}
    </update>

    <select id="countAll" resultType="int">SELECT COUNT(*) FROM shipping_templates</select>
</mapper>
