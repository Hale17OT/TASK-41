<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.dispatchops.infrastructure.persistence.mapper.TaskCommentMapper">

    <resultMap id="TaskCommentResultMap" type="TaskComment">
        <id property="id" column="id"/>
        <result property="taskId" column="task_id"/>
        <result property="authorId" column="author_id"/>
        <result property="body" column="body"/>
        <result property="createdAt" column="created_at"/>
    </resultMap>

    <select id="findByTaskId" resultMap="TaskCommentResultMap">
        SELECT * FROM task_comments WHERE task_id = #{taskId} ORDER BY created_at ASC
    </select>

    <insert id="insert" parameterType="TaskComment" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO task_comments (task_id, author_id, body)
        VALUES (#{taskId}, #{authorId}, #{body})
    </insert>

</mapper>
