<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.dispatchops.infrastructure.persistence.mapper.DeviceCredentialMapper">

    <resultMap id="DeviceCredentialResultMap" type="DeviceCredential">
        <id property="id" column="id"/>
        <result property="deviceId" column="device_id"/>
        <result property="deviceName" column="device_name"/>
        <result property="sharedSecret" column="shared_secret"/>
        <result property="active" column="is_active"/>
        <result property="createdAt" column="created_at"/>
    </resultMap>

    <select id="findByDeviceId" resultMap="DeviceCredentialResultMap">
        SELECT * FROM device_credentials WHERE device_id = #{deviceId} AND is_active = 1
    </select>

    <insert id="insert" parameterType="DeviceCredential" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO device_credentials (device_id, device_name, shared_secret)
        VALUES (#{deviceId}, #{deviceName}, #{sharedSecret})
    </insert>

</mapper>
