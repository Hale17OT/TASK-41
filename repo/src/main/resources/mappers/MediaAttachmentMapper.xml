<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.dispatchops.infrastructure.persistence.mapper.MediaAttachmentMapper">

    <resultMap id="MediaAttachmentResultMap" type="MediaAttachment">
        <id property="id" column="id"/>
        <result property="entityType" column="entity_type"/>
        <result property="entityId" column="entity_id"/>
        <result property="uploaderId" column="uploader_id"/>
        <result property="fileName" column="file_name"/>
        <result property="filePath" column="file_path"/>
        <result property="fileSize" column="file_size"/>
        <result property="mimeType" column="mime_type"/>
        <result property="visibilityLevel" column="visibility_level"/>
        <result property="active" column="is_active"/>
        <result property="createdAt" column="created_at"/>
    </resultMap>

    <select id="findById" resultMap="MediaAttachmentResultMap">
        SELECT * FROM media_attachments WHERE id = #{id}
    </select>

    <select id="findByEntity" resultMap="MediaAttachmentResultMap">
        SELECT * FROM media_attachments
        WHERE entity_type = #{entityType}
          AND entity_id = #{entityId}
          AND visibility_level &lt;= #{maxVisibility}
          AND is_active = 1
        ORDER BY created_at DESC
    </select>

    <insert id="insert" parameterType="MediaAttachment" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO media_attachments (entity_type, entity_id, uploader_id, file_name, file_path,
                                       file_size, mime_type, visibility_level)
        VALUES (#{entityType}, #{entityId}, #{uploaderId}, #{fileName}, #{filePath},
                #{fileSize}, #{mimeType}, #{visibilityLevel})
    </insert>

    <update id="deactivate">
        UPDATE media_attachments
        SET is_active = 0
        WHERE id = #{id}
    </update>

</mapper>
