<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.dispatchops.infrastructure.persistence.mapper.LanRelaySubMapper">

    <resultMap id="LanRelaySubResultMap" type="LanRelaySub">
        <id property="id" column="id"/>
        <result property="userId" column="user_id"/>
        <result property="topic" column="topic"/>
        <result property="active" column="is_active"/>
        <result property="createdAt" column="created_at"/>
    </resultMap>

    <select id="findByUserId" resultMap="LanRelaySubResultMap">
        SELECT * FROM lan_relay_subscriptions
        WHERE user_id = #{userId}
          AND is_active = 1
        ORDER BY created_at ASC
    </select>

    <select id="findByTopic" resultMap="LanRelaySubResultMap">
        SELECT * FROM lan_relay_subscriptions
        WHERE topic = #{topic}
          AND is_active = 1
        ORDER BY created_at ASC
    </select>

    <insert id="insert" parameterType="LanRelaySub" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO lan_relay_subscriptions (user_id, topic)
        VALUES (#{userId}, #{topic})
    </insert>

    <update id="deactivate">
        UPDATE lan_relay_subscriptions
        SET is_active = 0
        WHERE user_id = #{userId}
          AND topic = #{topic}
    </update>

</mapper>
