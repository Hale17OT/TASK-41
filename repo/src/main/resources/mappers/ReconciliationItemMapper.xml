<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.dispatchops.infrastructure.persistence.mapper.ReconciliationItemMapper">

    <resultMap id="ReconciliationItemResultMap" type="ReconciliationItem">
        <id property="id" column="id"/>
        <result property="paymentIdA" column="payment_id_a"/>
        <result property="paymentIdB" column="payment_id_b"/>
        <result property="conflictType" column="conflict_type"/>
        <result property="status" column="status"/>
        <result property="resolvedBy" column="resolved_by"/>
        <result property="resolutionNote" column="resolution_note"/>
        <result property="createdAt" column="created_at"/>
        <result property="resolvedAt" column="resolved_at"/>
    </resultMap>

    <select id="findById" resultMap="ReconciliationItemResultMap">
        SELECT * FROM reconciliation_queue WHERE id = #{id}
    </select>

    <select id="findByStatus" resultMap="ReconciliationItemResultMap">
        SELECT * FROM reconciliation_queue
        <where>
            <if test="status != null and status != ''">
                status = #{status}
            </if>
        </where>
        ORDER BY created_at ASC
        LIMIT #{limit} OFFSET #{offset}
    </select>

    <insert id="insert" parameterType="ReconciliationItem" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO reconciliation_queue (payment_id_a, payment_id_b, conflict_type, status)
        VALUES (#{paymentIdA}, #{paymentIdB}, #{conflictType}, #{status})
    </insert>

    <update id="resolve">
        UPDATE reconciliation_queue
        SET status          = #{status},
            resolved_by     = #{resolvedBy},
            resolution_note = #{note},
            resolved_at     = #{resolvedAt}
        WHERE id = #{id}
    </update>

    <select id="countByStatus" resultType="int">SELECT COUNT(*) FROM reconciliation_queue <where><if test="status != null and status != ''">status = #{status}</if></where></select>
</mapper>
