<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.dispatchops.infrastructure.persistence.mapper.TrendingTermMapper">

    <resultMap id="TrendingTermResultMap" type="TrendingTerm">
        <id property="id" column="id"/>
        <result property="term" column="term"/>
        <result property="searchCount" column="search_count"/>
        <result property="periodStart" column="period_start"/>
        <result property="periodEnd" column="period_end"/>
        <result property="calculatedAt" column="calculated_at"/>
    </resultMap>

    <select id="findRecent" resultMap="TrendingTermResultMap">
        SELECT * FROM trending_terms
        ORDER BY calculated_at DESC, search_count DESC
        LIMIT #{limit}
    </select>

    <delete id="deleteOlderThan">
        DELETE FROM trending_terms WHERE calculated_at &lt; #{cutoff}
    </delete>

    <insert id="insert" parameterType="TrendingTerm" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO trending_terms (term, search_count, period_start, period_end, calculated_at)
        VALUES (#{term}, #{searchCount}, #{periodStart}, #{periodEnd}, #{calculatedAt})
    </insert>

</mapper>
